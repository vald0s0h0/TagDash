# Node
node_modules
dist
dist-ssr
*.local

# TypeScript incremental build cache (machine-specific; a stale committed copy
# referencing a non-existent project breaks `tsc -b` / `npm run build`).
*.tsbuildinfo

# IDE
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Tauri / Rust
src-tauri/target
src-tauri/gen/schemas
# Cargo.lock is committed (this is an application, not a library) so CI
# resolves the exact dependency versions verified locally instead of
# re-resolving fresh and picking up breaking releases (e.g. time vs cookie).

# Tauri updater signing keys — NEVER commit the private key.
# (Generated by `tauri signer generate`; the `-w ~/...` created a literal `~` dir.)
/~/
*.key
tauri-signing.key*

# Env
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
