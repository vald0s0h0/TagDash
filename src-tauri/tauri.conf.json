{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TagDash",
  "version": "0.2.5",
  "identifier": "com.tagdash.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TagDash",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 720,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "theme": "Dark",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/defaults/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vald0s0h0/TagDash/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDRDQ5NjhGQkQyMTZBM0MKUldROGFpRzlqNWJVZkh5Z0J4SW1VMWxYQnM0NEV4MmxRNjd0aWsrRGhzQWlIakhXMmxkWjRrRFEK"
    }
  }
}
